<form class="rmu-migration-form" autocomplete="off">
    <p class="notes">{{localize "rmu.migration.description"}}</p>

    <div class="form-group" style="margin-top: 15px;">
        <button type="button" data-action="applyRMU" style="background: rgba(0, 255, 0, 0.1); border: 1px solid green; width: 100%;">
            {{localize "rmu.migration.applyRMU"}}
        </button>
    </div>

    <div class="form-group" style="margin-top: 10px;">
        <button type="button" data-action="restoreFoundry" style="background: rgba(255, 0, 0, 0.1); border: 1px solid red; width: 100%;">
            {{localize "rmu.migration.restoreFoundry"}}
        </button>
    </div>
</form>